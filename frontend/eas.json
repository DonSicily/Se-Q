{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "production": {
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "MAPBOX_ACCESS_TOKEN": "pk.your_public_token_here"
      }
    },
    "preview": {
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
      "env": {
        "MAPBOX_ACCESS_TOKEN": "pk.your_public_token_here"
      }
    },
    "development": {
      "node": "20.19.4",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "MAPBOX_ACCESS_TOKEN": "pk.your_public_token_here"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
